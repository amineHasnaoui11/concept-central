# =================================================================
# CONCEPT CENTRAL — Configuration d'environnement
# Copiez ce fichier vers `.env` et adaptez les valeurs.
# =================================================================

# --- Django ---
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de données ---
# SQLite par défaut (dev). Pour PostgreSQL en production :
# DATABASE_URL=postgres://user:password@db:5432/concept_central
DATABASE_URL=sqlite:///db.sqlite3

# --- Sécurité (Production uniquement, mettre à True derrière HTTPS) ---
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- Session ---
# Timeout d'inactivité en minutes (staff)
SESSION_IDLE_TIMEOUT_MINUTES=30

# --- Email ---
# Mode dev (affiche les emails dans le terminal) :
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Mode prod (Gmail SMTP) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Pour Gmail : utilisez un "mot de passe d'application"
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ecole.tn

# --- Site ---
SITE_URL=http://127.0.0.1:8000
SITE_NAME=Concept Central

# --- IA locale (Ollama) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- APIs externes (optionnel) ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Rate limiting (portail famille) ---
FAMILY_RATE_LIMIT=5/h

# --- Conformité ---
# Durée de conservation des dossiers psychologiques (années)
PSYCH_DOSSIER_RETENTION_YEARS=5
